{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false,
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.0",
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "disabled": true
      },
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_API_URL": "https://trip-sync-v2.vercel.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://socket.tripsync.live",
        "EXPO_PUBLIC_LIVEKIT_URL": "wss://voice.tripsync.live"
      },
      "releaseChannel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.0",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://trip-sync-v2.vercel.app",
        "EXPO_PUBLIC_SOCKET_URL": "https://socket.tripsync.live",
        "EXPO_PUBLIC_LIVEKIT_URL": "wss://voice.tripsync.live"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
