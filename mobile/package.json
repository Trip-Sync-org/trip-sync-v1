{
  "name": "mobile",
  "version": "1.0.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "main": "index.ts",
  "scripts": {
    "check-node": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/check-node.ps1",
    "typecheck": "tsc --noEmit",
    "build:preview": "npx --yes eas-cli@latest build --platform android --profile preview",
    "build:prod": "npx --yes eas-cli@latest build --platform android --profile production",
    "eas:android": "npx --yes eas-cli@latest build --platform android --profile preview",
    "eas:android:production": "npx --yes eas-cli@latest build --platform android --profile production",
    "expo:start": "expo start",
    "expo:tunnel": "expo start --tunnel",
    "start": "expo start",
    "run:android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-expo-android.ps1",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/vector-icons": "^15.0.3",
    "@livekit/react-native": "^2.10.2",
    "@livekit/react-native-webrtc": "^144.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.8",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "@supabase/supabase-js": "^2.100.1",
    "expo": "~54.0.27",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~5.0.0",
    "expo-constants": "^18.0.13",
    "expo-crypto": "~13.0.0",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-intent-launcher": "~13.0.8",
    "expo-location": "~19.0.8",
    "expo-modules-autolinking": "3.0.24",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~14.2.0",
    "livekit-client": "^2.18.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "react-native-webrtc"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-incall-manager",
          "react-native-webrtc"
        ]
      }
    }
  },
  "private": true
}
